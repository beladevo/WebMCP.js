{
  "name": "@webmcp-js/core",
  "version": "0.1.2",
  "description": "Type-safe WebMCP toolkit for registering validated, approval-aware browser tools.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "webmcp",
    "mcp",
    "model-context-protocol",
    "browser-ai",
    "ai-tools",
    "agent-tools",
    "tool-calling",
    "structured-tools",
    "typescript",
    "zod",
    "json-schema",
    "approval-workflow",
    "audit",
    "safety"
  ],
  "homepage": "https://github.com/webmcp-js/webmcp-js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webmcp-js/webmcp-js.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/webmcp-js/webmcp-js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --sourcemap --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.25.32",
    "zod-to-json-schema": "^3.24.5"
  }
}
